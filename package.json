  },
  "dependencies": {
    "axe-core": "^4.9.0",
    "commander": "^12.0.0",
    "parse5": "^7.1.2",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.44.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.0",
    "happy-dom": "^13.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
