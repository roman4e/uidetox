{
  "name": "uidetox",
  "version": "0.0.1",
  "type": "module",
  "description": "HTML-first Web Components framework with Markdown SFCs",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli/build.ts"
  },
  "bin": {
